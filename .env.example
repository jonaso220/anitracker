# Copiá este archivo a .env.local y completá tus valores.
# Las claves Web de Firebase y la API key de TMDB no son secretas en una app
# de navegador, pero .env* está en .gitignore igualmente.

# --- Firebase (opcional) ---
# Si no se configuran, la app usa el proyecto público compartido.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- TMDB (opcional, recomendado) ---
# Habilita búsqueda de películas/series con metadatos en español y
# "dónde ver" por país (Netflix, Disney+, etc. — datos de JustWatch).
# Registrate gratis en https://www.themoviedb.org/settings/api y pegá acá
# tu "API Key" (v3) o el "Token de acceso de lectura" (v4).
VITE_TMDB_API_KEY=
